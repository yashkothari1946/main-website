# ══════════════════════════════════════════════════
#  VYBTEK PRODUCTION PERFORMANCE .htaccess
# ══════════════════════════════════════════════════

# Clean URL rewrites (.html extension optional)
RewriteEngine On
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [NC,L]

# ── GZIP / BROTLI COMPRESSION ──────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml application/xml
  AddOutputFilterByType DEFLATE font/woff font/woff2 font/ttf
</IfModule>

# ── BROWSER CACHING ────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  
  # HTML — short cache (content changes often)
  ExpiresByType text/html                  "access plus 1 hour"
  
  # CSS & JS — long cache (versioned in filenames)
  ExpiresByType text/css                   "access plus 1 year"
  ExpiresByType application/javascript     "access plus 1 year"
  ExpiresByType text/javascript            "access plus 1 year"
  
  # Images
  ExpiresByType image/png                  "access plus 1 year"
  ExpiresByType image/jpeg                 "access plus 1 year"
  ExpiresByType image/gif                  "access plus 1 year"
  ExpiresByType image/webp                 "access plus 1 year"
  ExpiresByType image/svg+xml              "access plus 1 year"
  ExpiresByType image/x-icon              "access plus 1 year"
  
  # Fonts
  ExpiresByType font/woff                  "access plus 1 year"
  ExpiresByType font/woff2                 "access plus 1 year"
  ExpiresByType application/font-woff      "access plus 1 year"
</IfModule>

# ── SECURITY & PERFORMANCE HEADERS ────────────────
<IfModule mod_headers.c>
  # Keep connections alive for faster subsequent requests
  Header set Connection keep-alive

  # Security
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Cache control for static assets
  <FilesMatch "\.(css|js|png|jpg|jpeg|gif|webp|svg|ico|woff|woff2|ttf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  
  # Cache control for HTML
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>

  # Remove X-Powered-By header
  Header always unset X-Powered-By
</IfModule>

# ── KEEP-ALIVE ─────────────────────────────────────
<IfModule mod_headers.c>
  Header set Connection keep-alive
</IfModule>

# ── ETags (better cache validation) ────────────────
FileETag MTime Size
